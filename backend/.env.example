APP_NAME=Securite Audit API
API_PREFIX=/api
DATABASE_URL=postgresql+asyncpg://securix:securix@db:5432/securix
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AWS credentials (either env vars, mounted profile, or IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Azure auth with DefaultAzureCredential
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# GCP ADC
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-service-account.json
